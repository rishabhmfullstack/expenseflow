generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  EMPLOYEE
  MANAGER
  SENIOR_MANAGER
  ADMIN
}

enum ClaimStatus {
  DRAFT
  REVERTED_TO_EMPLOYEE
  PENDING_MANAGER
  REVERTED_TO_MANAGER
  PENDING_SENIOR_MANAGER
  APPROVED
  REJECTED
  CANCELLED
}

enum ExpenseCategory {
  TRAVEL
  MEALS
  ACCOMMODATION
  SUPPLIES
  SOFTWARE
  TRAINING
  OTHER
}

enum ApprovalAction {
  SUBMITTED
  RESUBMITTED
  APPROVED
  REJECTED
  CANCELLED
  REVISION_REQUESTED
}

enum ApprovalStep {
  MANAGER
  SENIOR_MANAGER
  ADMIN
}

model User {
  id           String   @id @default(uuid()) @db.Uuid
  email        String   @unique @db.VarChar(255)
  passwordHash String   @map("password_hash") @db.VarChar(255)
  firstName    String   @map("first_name") @db.VarChar(100)
  lastName     String   @map("last_name") @db.VarChar(100)
  role         Role
  managerId    String?  @map("manager_id") @db.Uuid
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz(6)

  manager       User?  @relation("UserReports", fields: [managerId], references: [id], onDelete: Restrict)
  directReports User[] @relation("UserReports")

  claims          Claim[]           @relation("ClaimEmployee")
  pendingClaims   Claim[]           @relation("ClaimPendingWith")
  approvalActions ApprovalHistory[] @relation("ApprovalActor")
  refreshTokens   RefreshToken[]

  @@index([managerId], name: "idx_users_manager_id")
  @@index([role], name: "idx_users_role")
  @@index([role, isActive], name: "idx_users_role_active")
  @@map("users")
}

model Claim {
  id          String          @id @default(uuid()) @db.Uuid
  employeeId  String          @map("employee_id") @db.Uuid
  amount      Decimal         @db.Decimal(12, 2)
  category    ExpenseCategory
  description String          @db.Text
  receiptUrl  String?         @map("receipt_url") @db.VarChar(500)
  expenseDate DateTime        @map("expense_date") @db.Date
  status      ClaimStatus     @default(DRAFT)
  pendingWith String?         @map("pending_with") @db.Uuid
  createdAt   DateTime        @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime        @updatedAt @map("updated_at") @db.Timestamptz(6)

  employee        User              @relation("ClaimEmployee", fields: [employeeId], references: [id], onDelete: Restrict)
  pendingApprover User?             @relation("ClaimPendingWith", fields: [pendingWith], references: [id], onDelete: SetNull)
  approvalHistory ApprovalHistory[]

  @@index([employeeId, createdAt(sort: Desc)], name: "idx_claims_employee_created")
  @@index([employeeId, status], name: "idx_claims_employee_status")
  @@index([pendingWith, status], name: "idx_claims_pending_with_status")
  @@index([status, createdAt(sort: Desc)], name: "idx_claims_status_created")
  @@index([status, expenseDate(sort: Desc)], name: "idx_claims_status_expense_date")
  @@index([expenseDate(sort: Desc)], name: "idx_claims_expense_date")
  @@index([createdAt(sort: Desc)], name: "idx_claims_created_at")
  @@map("claims")
}

model ApprovalHistory {
  id        String         @id @default(uuid()) @db.Uuid
  claimId   String         @map("claim_id") @db.Uuid
  actorId   String         @map("actor_id") @db.Uuid
  action    ApprovalAction
  step      ApprovalStep
  note      String?        @db.Text
  createdAt DateTime       @default(now()) @map("created_at") @db.Timestamptz(6)

  claim Claim @relation(fields: [claimId], references: [id], onDelete: Restrict)
  actor User  @relation("ApprovalActor", fields: [actorId], references: [id], onDelete: Restrict)

  @@index([claimId, createdAt(sort: Asc)], name: "idx_approval_history_claim_created")
  @@index([actorId, createdAt(sort: Desc)], name: "idx_approval_history_actor_created")
  @@map("approval_history")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @unique @map("token_hash") @db.VarChar(255)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz(6)
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz(6)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, revokedAt], name: "idx_refresh_tokens_user_revoked")
  @@index([expiresAt], name: "idx_refresh_tokens_expires_at")
  @@map("refresh_tokens")
}
